# Local Jenkins controller — copy to .env and fill in.
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin

# GHCR pull (private packages): GitHub user + a PAT with read:packages
GHCR_USER=your-github-user
GHCR_TOKEN=ghp_xxx

# Repo clone (private): GitHub user + a PAT with repo scope
GIT_USER=your-github-user
GIT_TOKEN=ghp_xxx
