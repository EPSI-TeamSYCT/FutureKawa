PORT=3000
LOG_LEVEL=info

# Sovereign country APIs: one base URL per country. HQ fans out to all
# configured countries and merges the results. Configure only the ones you run
# (at least one is required).
COUNTRY_API_URL_BRAZIL=http://localhost:8081
COUNTRY_API_URL_ECUADOR=http://localhost:8082
COUNTRY_API_URL_COLOMBIA=http://localhost:8083

# Backward-compatible fallback: if no per-country URL is set, HQ uses this
# single URL as one country.
# COUNTRY_API_URL=http://localhost:8080

# Shared API key sent as X-API-KEY to every country API.
COUNTRY_API_KEY=change-me

COUNTRY_TIMEOUT_MS=4000
CACHE_STALE_MS=300000
