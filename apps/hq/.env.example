# HQ ("siège") configuration for apps/hq/docker-compose.yml.
# Copy to .env on the VPS and adjust.
#
#   cp .env.example .env

# --- Image source (container registry) -------------------------------------
# Same registry you used for country-api / iot-simulator.
#   Docker Hub: REGISTRY=docker.io/<your-dockerhub-user>
#   GHCR:       REGISTRY=ghcr.io/epsi-teamsyct
REGISTRY=docker.io/<your-dockerhub-user>
IMAGE_TAG=latest

# --- Public routing (Traefik) ----------------------------------------------
# Subdomain served by the existing Traefik instance for the HQ SPA.
SIEGE_DOMAIN=siege.futurekawa.thom-it.fr
# Must match your Traefik static config (HTTPS entrypoint + ACME certresolver).
TRAEFIK_ENTRYPOINT=websecure
CERT_RESOLVER=le

# --- Sovereign country APIs (public HTTPS) ---------------------------------
# Base URLs only — the backend appends /api/... itself (do NOT add /api here).
COUNTRY_API_URL_BRAZIL=https://api.brazil.futurekawa.thom-it.fr
COUNTRY_API_URL_ECUADOR=https://api.equator.futurekawa.thom-it.fr
COUNTRY_API_URL_COLOMBIA=https://api.colombia.futurekawa.thom-it.fr

# Shared key sent as X-API-KEY to every country API.
# MUST equal COUNTRY_API_KEY of each country deployment, or calls get 401.
COUNTRY_API_KEY=change-me

# --- Tuning (optional) -----------------------------------------------------
LOG_LEVEL=info
# Per-country HTTP timeout (ms) before HQ falls back to its stale cache.
COUNTRY_TIMEOUT_MS=4000
# How long a cached country snapshot stays usable as a fallback (ms).
CACHE_STALE_MS=300000
