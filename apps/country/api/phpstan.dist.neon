includes:
    # Pre-existing Doctrine entity findings (id set by the ORM via reflection).
    # Regenerate with: vendor/bin/phpstan analyse --generate-baseline
    - phpstan-baseline.neon

parameters:
    level: 6
    paths:
        - src
    # Symfony-aware analysis can be sharpened later by adding the
    # phpstan/phpstan-symfony extension to require-dev.
