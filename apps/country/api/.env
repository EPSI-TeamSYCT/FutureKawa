# Base environment defaults (loaded in every env, overridden by .env.local /
# .env.<env> / the real environment). No secret here — real values come from the
# deployment environment (docker compose / .env.local).

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Passwordless by default; the real DATABASE_URL is provided by the environment.
DATABASE_URL="postgresql://app@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# Transport for alert e-mails. "null://null" swallows mail so demos/CI run
# without an SMTP server. Provide a real DSN in the deployment environment, e.g.
# MAILER_DSN=smtp://user:pass@smtp.example.com:587 (real secret lives in .env.local).
MAILER_DSN=null://null
# From address used on alert notifications.
ALERT_MAIL_FROM=alerts@futurekawa.example
###< symfony/mailer ###
