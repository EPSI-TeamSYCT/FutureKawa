# Per-country configuration for apps/country/docker-compose.yml.
# Copy to .env and adjust per country. Deploy one stack per country.
#
#   cp .env.example .env

# --- Image source (container registry) -------------------------------------
# Docker Hub: set REGISTRY to your Docker Hub namespace (username or org).
#   REGISTRY=docker.io/<your-dockerhub-user>
# GHCR alternative: REGISTRY=ghcr.io/epsi-teamsyct
REGISTRY=docker.io/<your-dockerhub-user>
IMAGE_TAG=latest

# --- Country identity ------------------------------------------------------
COUNTRY=brazil

# One JSON object per IoT device. A warehouse may host several devices.
# model is optional (default "DHT11").
DEVICES=[{"warehouse":"wh-01","hardware_id":"br-wh-01"},{"warehouse":"wh-02","hardware_id":"br-wh-02"}]

# --- Ideal storage conditions (per country) --------------------------------
# Brazil 29/55 · Ecuador 31/60 · Colombia 26/80
TEMP_THRESHOLD=29
HUMIDITY_THRESHOLD=55

# Publish period, seconds.
PUBLISH_INTERVAL=30

# --- Public routing (Traefik) ----------------------------------------------
# Domain served by the existing Traefik instance for THIS country's API.
API_DOMAIN=api.brazil.futurekawa.domain.example
# Traefik entrypoint (HTTPS) and ACME certresolver names — must match your
# Traefik static config. Check with:
#   docker inspect <traefik> --format '{{join .Args " "}}' | tr ' ' '\n' | grep -iE 'entrypoint|certresolver'
TRAEFIK_ENTRYPOINT=websecure
CERT_RESOLVER=le

# --- API secrets -----------------------------------------------------------
# Symfony app secret — generate with:  openssl rand -hex 16
APP_SECRET=
# Shared key required by every request to the country API (X-API-KEY header).
COUNTRY_API_KEY=change-me

# --- Country database ------------------------------------------------------
DB_USER=futurekawa
DB_NAME=futurekawa
DB_PASSWORD=

# --- MQTT (broker is internal; anonymous by default) -----------------------
MQTT_USER=futurekawa
MQTT_PASSWORD=secret
