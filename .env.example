# Configuration for the HQ stack (docker-compose.yml at the repo root).
# Copy to .env and adjust.

# --- Image source (GHCR) ---
REGISTRY=ghcr.io/epsi-teamsyct
IMAGE_TAG=latest

# --- Backend ↔ country API ---
# Shared API key sent to the country API(s).
COUNTRY_API_KEY=change-me
# Single-URL mode (as currently built): which country API the backend queries.
COUNTRY_API_URL=http://stack-brazil:8000
