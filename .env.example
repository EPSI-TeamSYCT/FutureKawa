# Configuration for the FULL-STACK compose (docker-compose.yml at the repo root).
# One `docker compose up` runs the WHOLE system: the three sovereign country
# edges (Brazil, Ecuador, Colombia) + the HQ backend + frontend.
# Copy to .env and adjust. Placeholders below are NOT secrets -- replace them.
#
# Per-country settings (COUNTRY, DEVICES, thresholds, the three API URLs) are
# baked into docker-compose.yml, so this file only carries the SHARED values.

# --- Image source (GHCR) ---
# All custom images are pulled from GHCR (built once by the CD). `docker login
# ghcr.io` first, or make the packages public for the demo.
REGISTRY=ghcr.io/epsi-teamsyct
IMAGE_TAG=latest

# --- Shared secrets (required) ---
# Symfony app secret for the country APIs, and the key the HQ backend sends as
# X-API-KEY to every country API (each country API validates against it).
APP_SECRET=change-me
COUNTRY_API_KEY=change-me

# --- Country databases (Postgres) — same creds, one volume per country ---
DB_USER=futurekawa
DB_NAME=futurekawa
DB_PASSWORD=change-me-strong

# --- IoT simulator ---
# Publish period in seconds (applies to all three simulators).
PUBLISH_INTERVAL=30
