# Configuration for the FULL-STACK compose (docker-compose.yml at the repo root).
# One `docker compose up` runs the whole system: the Brazil country edge
# (broker + simulator + API + DB + worker) plus the HQ backend + frontend.
# Copy to .env and adjust. Placeholders below are NOT secrets -- replace them.

# --- Image source (GHCR) ---
REGISTRY=ghcr.io/epsi-teamsyct
IMAGE_TAG=latest

# --- Country identity ---
COUNTRY=brazil

# One JSON object per IoT device. A warehouse may host several devices.
# model is optional (default "DHT11").
DEVICES=[{"warehouse":"wh-01","hardware_id":"br-wh-01"},{"warehouse":"wh-02","hardware_id":"br-wh-02"}]

# --- Ideal storage conditions (per country) ---
# Brazil 29/55 - Ecuador 31/60 - Colombia 26/80
TEMP_THRESHOLD=29
HUMIDITY_THRESHOLD=55

# Publish period, seconds.
PUBLISH_INTERVAL=30

# --- Country API (Symfony) ---
# Shared key sent as X-API-KEY, and the Symfony app secret (required).
COUNTRY_API_KEY=change-me
APP_SECRET=change-me

# --- Country database (Postgres) ---
DB_USER=futurekawa
DB_NAME=futurekawa
DB_PASSWORD=change-me-strong

# --- MQTT broker credentials (empty = anonymous, matches the dev broker) ---
MQTT_USER=
MQTT_PASSWORD=

# --- HQ backend -> country API ---
# Single-URL mode (as built on main today): the backend queries this one API.
# Defaults to the in-network country-api service, so this rarely needs changing.
COUNTRY_API_URL=http://country-api:8000
# 3-country target (needs the in-flight multi-URL backend change); optional:
# COUNTRY_API_URL_BRAZIL=http://country-api:8000
# COUNTRY_API_URL_ECUADOR=http://country-api-ecuador:8000
# COUNTRY_API_URL_COLOMBIA=http://country-api-colombia:8000
